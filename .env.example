# --- Required Environment Variables ---
EXPO_PUBLIC_API_AUTH_BASE_URL=http://127.0.0.1:8000
EXPO_PUBLIC_USER_SESSION_KEY=dev-session-key
EXPO_PUBLIC_USER_PROFILE_KEY=dev-profile-key

# --- Local Overrides (Do NOT commit these) ---
# .env.local: For unique machine-specific secrets (e.g., personal API keys).
# .env: General environment variables (if containing any non-public secrets).
# .env.production.local: Production override configuration if it contains secret keys.